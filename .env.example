# ── GraphMind — Backend environment template ───────────────────
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
#   cp .env.example .env

# ── Neo4j ──────────────────────────────────────────────────────
# Local Docker:      bolt://localhost:7687
# Neo4j Aura (prod): neo4j+s://<dbid>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# ── LLM API keys ───────────────────────────────────────────────
# Primary: Groq. Fallback: Google Gemini.
GROQ_API_KEY=
GEMINI_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.0-flash

# ── Clerk auth (optional — production RS256 JWT) ───────────────
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# CLERK_JWKS_URL is auto-derived from the publishable key if left blank.

# ── Own HS256 JWT (used by /auth/signup + /auth/login) ─────────
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Application / deployment ───────────────────────────────────
# development | production
APP_ENV=development
# Port the backend binds to (deployment platforms inject this automatically).
PORT=8000
# CORS: unset = dev defaults (localhost:5173). In production set this to your
# frontend origin, e.g. https://graphmind.vercel.app  (comma-separate multiple).
# Use "*" only for quick tests (credentials are disabled when it is "*").
CORS_ORIGINS=
