# ── GraphMind — Frontend environment template ──────────────────
# Copy to `.env` (or `.env.production`) and set as needed.
#   cp .env.example .env

# Backend origin for the PRODUCTION build (static build has no dev proxy).
# No trailing slash, no '/api' suffix — backend routes live at the root.
# Example: https://graphmind-api.onrender.com
# Leave blank for local dev — requests fall back to '/api' (the Vite proxy).
VITE_API_URL=

# Dev-only: where the Vite dev-server proxy forwards /api requests.
# Defaults to http://localhost:8000 when unset.
VITE_DEV_PROXY_TARGET=http://localhost:8000
